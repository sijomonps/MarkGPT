{
  "manifest_version": 3,
  "name": "MarkGPT – Bookmark Messages in ChatGPT, Claude & Gemini",
  "short_name": "MarkGPT",
  "version": "1.0.0",
  "description": "Bookmark and quickly jump to important messages in ChatGPT, Claude, and Gemini conversations.",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icons16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "MarkGPT",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icons16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
